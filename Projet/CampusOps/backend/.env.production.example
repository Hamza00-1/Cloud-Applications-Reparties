# ============================================
# CampusOps Backend — Production env template
# ============================================
# Copy to your hosting provider's secret store
# (Render env group, Railway variables, etc.).
# NEVER commit a populated copy of this file.
# ============================================

NODE_ENV=production
PORT=3000
API_PREFIX=/api

# ---------- Database (managed Postgres) ----------
# Supabase: Project Settings → Database → Connection string (URI mode)
# Neon:     Connection Details → Connection string
# Render:   Internal Database URL (preferred for in-network calls)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ---------- Redis (optional in prod — leave default if unused) ----------
REDIS_URL=redis://default:PASSWORD@HOST:6379

# ---------- JWT — REQUIRED, use strong random values ----------
# Generate with:  openssl rand -base64 64
JWT_ACCESS_SECRET=REPLACE_WITH_LONG_RANDOM_BASE64_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_LONG_RANDOM_BASE64_STRING
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---------- Bcrypt ----------
BCRYPT_SALT_ROUNDS=12

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---------- CORS — your deployed frontend URL ----------
CORS_ORIGIN=https://campusops.vercel.app

# ---------- Public app URL (for links in emails) ----------
APP_URL=https://campusops.vercel.app

# ---------- Logging ----------
LOG_LEVEL=info

# ---------- SMTP ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@campusops.ma
SMTP_PASS=REPLACE_ME
SMTP_FROM=CampusOps <noreply@campusops.ma>

# ---------- IMAP (optional — needed for GET /api/mail/latest) ----------
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=noreply@campusops.ma
IMAP_PASS=REPLACE_ME

# ---------- Telegram bot (optional) ----------
TELEGRAM_BOT_TOKEN=

# ---------- OpenClaw webhooks ----------
OPENCLAW_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_HMAC_SECRET

# ---------- Cron ----------
CRON_DAILY_PLANNING=on
CRON_DAILY_PLANNING_TIME=0 7 * * *
CRON_TIMEZONE=Africa/Casablanca
