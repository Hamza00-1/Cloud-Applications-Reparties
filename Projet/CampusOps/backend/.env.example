# ============================================
# CampusOps Backend — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# Generate strong secrets with: openssl rand -base64 64
# NEVER commit .env to git.
# ============================================

# ---------- Server ----------
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql://campusops:campusops_secret@localhost:5432/campusops_db?schema=public

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- JWT Authentication ----------
# IMPORTANT: Use long random secrets. Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_run_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_run_openssl_rand_base64_64
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---------- Bcrypt ----------
BCRYPT_SALT_ROUNDS=12

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:5173

# ---------- App Public URL (used in email links) ----------
APP_URL=http://localhost:5173

# ---------- Logging ----------
LOG_LEVEL=debug

# ---------- Telegram Bot (Phase 5) ----------
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook

# ---------- Email / SMTP (Phase 5) ----------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=CampusOps <noreply@campusops.ma>

# ---------- IMAP inbox (Phase 6) ----------
# Falls back to SMTP_HOST/USER/PASS if omitted.
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_SECURE=true
# IMAP_USER=your-email@gmail.com
# IMAP_PASS=your-app-password

# ---------- OpenClaw webhooks (Phase 6) ----------
# Shared HMAC secret — incoming webhook bodies are signed with sha256.
# OPENCLAW_WEBHOOK_SECRET=change-me-shared-with-openclaw

# ---------- Cron (Phase 6) ----------
# Daily planning notifications. Disable in tests with CRON_DAILY_PLANNING=off.
CRON_DAILY_PLANNING=on
CRON_DAILY_PLANNING_TIME=0 7 * * *
CRON_TIMEZONE=Africa/Casablanca
