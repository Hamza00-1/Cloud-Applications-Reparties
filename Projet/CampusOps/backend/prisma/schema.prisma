// ============================================
// CampusOps — Prisma Schema (Phase 2: Full Schema)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum Role {
  Admin
  Scolarite
  Enseignant
  Etudiant
}

enum AbsenceStatus {
  Present
  Absent
  Late
}

enum PaymentPlanType {
  Inscription
  Mensualite
}

enum PaymentStatus {
  Paid
  Partial
  Unpaid
}

enum GradeType {
  Exam
  TD
  TP
  Project
}

enum NotificationType {
  info
  alert
  reminder
  success
}

// ============================================
// Core Organizational Models
// ============================================

model Branch {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users   User[]
  modules Module[]
  groups  Group[]

  @@map("branches")
}

model User {
  id              String   @id @default(uuid())
  branchId        String   @map("branch_id")
  name            String
  email           String   @unique
  passwordHash    String   @map("password_hash")
  role            Role     @default(Etudiant)
  telegramChatId  String?  @map("telegram_chat_id")
  whatsappNumber  String?  @map("whatsapp_number")
  otpCode         String?  @map("otp_code")
  refreshToken    String?  @map("refresh_token")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  branch        Branch         @relation(fields: [branchId], references: [id])
  plannings     Planning[]     @relation("TeacherPlannings")
  studentGroups GroupStudent[]
  absences      Absence[]      @relation("StudentAbsences")
  payments      Payment[]
  notifications Notification[]
  studentGrades Grade[]        @relation("StudentGrades")
  teacherGrades Grade[]        @relation("TeacherGrades")

  @@map("users")
}

model Module {
  id          String   @id @default(uuid())
  branchId    String   @map("branch_id")
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  branch    Branch     @relation(fields: [branchId], references: [id])
  plannings Planning[]
  progress  Progress[]
  grades    Grade[]

  @@map("modules")
}

model Group {
  id           String   @id @default(uuid())
  branchId     String   @map("branch_id")
  name         String
  academicYear String   @map("academic_year")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  branch    Branch         @relation(fields: [branchId], references: [id])
  students  GroupStudent[]
  plannings Planning[]
  progress  Progress[]

  @@map("groups")
}

model GroupStudent {
  groupId   String   @map("group_id")
  studentId String   @map("student_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  // Relations
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([groupId, studentId])
  @@map("group_students")
}

// ============================================
// Business Logic Models
// ============================================

model Planning {
  id        String   @id @default(uuid())
  moduleId  String   @map("module_id")
  groupId   String   @map("group_id")
  teacherId String   @map("teacher_id")
  room      String
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  module   Module    @relation(fields: [moduleId], references: [id])
  group    Group     @relation(fields: [groupId], references: [id])
  teacher  User      @relation("TeacherPlannings", fields: [teacherId], references: [id])
  absences Absence[]

  @@map("plannings")
}

model Absence {
  id                   String        @id @default(uuid())
  sessionId            String        @map("session_id")
  studentId            String        @map("student_id")
  status               AbsenceStatus
  justificationDocUrl  String?       @map("justification_doc_url")
  ocrTextExtracted     String?       @map("ocr_text_extracted") @db.Text
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  // Relations
  session Planning @relation(fields: [sessionId], references: [id])
  student User     @relation("StudentAbsences", fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@index([createdAt])
  @@map("absences")
}

model Progress {
  id             String   @id @default(uuid())
  moduleId       String   @map("module_id")
  groupId        String   @map("group_id")
  percentage     Int      @default(0)
  lastUpdatedById String  @map("last_updated_by_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  module        Module @relation(fields: [moduleId], references: [id])
  group         Group  @relation(fields: [groupId], references: [id])

  @@unique([moduleId, groupId])
  @@map("progress_tracking")
}

model Payment {
  id        String          @id @default(uuid())
  studentId String          @map("student_id")
  planType  PaymentPlanType @map("plan_type")
  amount    Decimal         @db.Decimal(10, 2)
  status    PaymentStatus   @default(Unpaid)
  dueDate   DateTime        @map("due_date") @db.Date
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  // Relations
  student User @relation(fields: [studentId], references: [id])

  @@map("payments")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  senderId  String?          @map("sender_id")
  title     String
  content   String           @db.Text
  type      NotificationType @default(info)
  channels  String[]         @default(["inapp"])
  audience  String?          // 'all', 'all_students', 'all_teachers', 'group', 'user'
  groupId   String?          @map("group_id")
  isRead    Boolean          @default(false) @map("is_read")
  emailSent Boolean          @default(false) @map("email_sent")
  telegramSent Boolean       @default(false) @map("telegram_sent")
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model Grade {
  id        String    @id @default(uuid())
  studentId String    @map("student_id")
  moduleId  String    @map("module_id")
  teacherId String    @map("teacher_id")
  value     Decimal   @db.Decimal(4, 2)
  gradeType GradeType @map("grade_type")
  semester  String    @default("S1-2024")
  comment   String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  student User   @relation("StudentGrades", fields: [studentId], references: [id])
  module  Module @relation(fields: [moduleId], references: [id])
  teacher User   @relation("TeacherGrades", fields: [teacherId], references: [id])

  @@unique([studentId, moduleId, gradeType, semester])
  @@index([studentId])
  @@index([createdAt])
  @@map("grades")
}
